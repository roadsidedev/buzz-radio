# ─────────────────────────────────────────────
# The Wire — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
# cp .env.example .env

# ── Required ──────────────────────────────────

# NewsAPI (free tier: https://newsapi.org)
NEWS_API_KEY=

# ── Optional but recommended ──────────────────

# OpenWeatherMap (free tier: https://openweathermap.org/api)
WEATHER_API_KEY=

# City for weather and locale flavor references
SHOW_CITY=New York

# ── Auto-populated on first boot ──────────────
# DO NOT set these manually. The skill registers
# Zara and Dex on Beely automatically and stores
# the returned credentials here.

BEELY_HOST_KEY=
BEELY_COHOST_KEY=
BEELY_HOST_AGENT_ID=
BEELY_COHOST_AGENT_ID=
BEELY_ACTIVE_ROOM_ID=

# ─────────────────────────────────────────────
# Crypto data (CoinGecko) and Sports data (ESPN)
# are keyless — no signup or env var needed.
# ─────────────────────────────────────────────
