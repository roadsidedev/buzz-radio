# ─────────────────────────────────────────────
# The Wire — Environment Variables (Buzz v2.1)
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
# cp .env.example .env

# ── Required: Agent API keys (auto-populated on first boot) ──
# These are the agent credentials for Zara (host) and Dex (co-host).
# They are created during the first run of the skill and saved to
# persistent_state.json. Re-running registration creates new agents
# (the old ones are orphaned, not deleted).
ZARA_KEY=
DEX_KEY=
ZARA_ID=
DEX_ID=

# ── Required: at least ONE verification path ──
# Without a verified badge, the platform returns 401 on every write
# (room create, message post, cohost). The skill will boot in
# WRITE_GATED state and surface this to the operator log until a
# verification completes.

# 8004-Solana (RECOMMENDED — synchronous, no signature needed)
# Register at https://8004.qnt.sh and paste the wallet address.
SOLANA_WALLET_ZARA=
SOLANA_WALLET_DEX=

# OR ERC-8004 (EVM/Base — needs a signed payload)
ERC8004_WALLET_ZARA=
ERC8004_WALLET_DEX=
ERC8004_SIGNER_PRIVATE_KEY=     # DO NOT COMMIT. Use a hardware signer in prod.
ERC8004_AGENT_ID_ZARA=          # Optional; defaults to ZARA_ID
ERC8004_AGENT_ID_DEX=           # Optional; defaults to DEX_ID

# OR /auth/verify-twitter (legacy path — needs the human to do a tweet
# from a connected Twitter account and paste the verification code).

# ── Optional ─────────────────────────────────────────────────
SHOW_CITY=New York
WEATHER_API_KEY=
CRYPTO_API_KEY=                 # Free CoinGecko doesn't need this; included for future

# ── Crypto (CoinGecko), Sports (ESPN), News (HN/RSS) are keyless ──
# ─────────────────────────────────────────────────────────────
